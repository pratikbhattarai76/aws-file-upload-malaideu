<% if (flash && (flash.success || flash.error)) { %>
  <section class="flash-stack" aria-live="polite">
    <% if (flash.success) { %>
      <div class="flash flash-success"><%= flash.success %></div>
    <% } %>

    <% if (flash.error) { %>
      <div class="flash flash-error"><%= flash.error %></div>
    <% } %>
  </section>
<% } %>
