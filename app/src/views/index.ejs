<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { pageTitle }) %>
  <body>
    <main class="page-shell">
      <%- include("partials/nav") %>
      <%- include("partials/flash", { flash }) %>

      <section class="hero-grid">
        <article class="hero-copy panel panel-hero">
          <p class="eyebrow">Lightweight file drop</p>
          <h1>Send a file now. Open it again later.</h1>
          <p class="lede">
            <%= appName %> keeps the flow simple: choose a file, upload it, and browse your library when
            you need it again.
          </p>

          <div class="hero-actions">
            <a class="button" href="#upload-card">Start uploading</a>
            <a class="button button-muted" href="/files">Open library</a>
          </div>

          <div class="hero-notes">
            <div>
              <strong>Clean flow</strong>
              <span>One upload surface, one simple library view.</span>
            </div>
            <div>
              <strong>Practical limits</strong>
              <span>Files up to <%= maxFileSize %> per upload.</span>
            </div>
          </div>
        </article>

        <section id="upload-card" class="panel upload-panel">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Drop zone</p>
              <h2>Upload a file</h2>
            </div>
            <span class="hint-pill">Single file</span>
          </div>

          <form class="upload-form" action="/upload" method="POST" enctype="multipart/form-data">
            <label class="dropzone" for="file-input" data-dropzone>
              <input id="file-input" type="file" name="file" required data-file-input />
              <span class="dropzone-icon">+</span>
              <strong>Drag and drop here</strong>
              <span>or click to choose a file</span>
              <small data-file-label>No file selected</small>
            </label>

            <div class="form-row">
              <button class="button" type="submit">Upload file</button>
              <a class="text-link" href="/files">Browse uploaded files</a>
            </div>
          </form>
        </section>
      </section>
    </main>
  </body>
</html>
